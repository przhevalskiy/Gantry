# LLM
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Web Search
TAVILY_API_KEY=tvly-...

# Agentex
AGENT_NAME=web-scout
ACP_URL=http://localhost:8000
ACP_PORT=8000
AGENTEX_BASE_URL=http://localhost:5003

# Temporal
TEMPORAL_ADDRESS=localhost:7233
WORKFLOW_NAME=web-scout
WORKFLOW_TASK_QUEUE=web_scout_queue

# Browser
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000

# Feature flags
USE_MOCK_BROWSER=false
USE_MOCK_SEARCH=false

# Hard caps
MAX_AGENT_TURNS=20
MAX_PAGES_PER_TASK=8
