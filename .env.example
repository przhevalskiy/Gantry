# LLM — Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# LLM — Mistral (optional alternative)
# Set MISTRAL_API_KEY and override model names below to use Mistral instead of Claude.
# Example: CLAUDE_SONNET_MODEL=mistral-large-latest routes all Sonnet agents to Mistral Large.
# MISTRAL_API_KEY=...
# CLAUDE_SONNET_MODEL=mistral-large-latest
# CLAUDE_HAIKU_MODEL=mistral-small-latest

# Web Search
TAVILY_API_KEY=tvly-...

# Agentex
AGENT_NAME=web-scout
ACP_URL=http://localhost:8000
ACP_PORT=8000
AGENTEX_BASE_URL=http://localhost:5003

# Temporal
TEMPORAL_ADDRESS=localhost:7233
WORKFLOW_NAME=web-scout
WORKFLOW_TASK_QUEUE=web_scout_queue

# Browser
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000

# Feature flags
USE_MOCK_BROWSER=false
USE_MOCK_SEARCH=false

# Hard caps
MAX_AGENT_TURNS=20
MAX_PAGES_PER_TASK=8
